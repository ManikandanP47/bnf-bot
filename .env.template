# ─────────────────────────────────────────────────────
# Multi-Agent BankNifty Bot — Configuration
# Copy to .env and fill values
# In Railway: add as Environment Variables
# ─────────────────────────────────────────────────────

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Telegram mirror — logs all bot messages for Cursor agent (scripts/pull_telegram_mirror.py)
TELEGRAM_MIRROR_ENABLED=true
TELEGRAM_MIRROR_FILE=telegram_mirror.jsonl
TELEGRAM_MIRROR_MAX_LINES=500
BOT_SERVER_SSH=root@YOUR_SERVER_IP

# Groww — data (LTP) + F&O execution (TOTP preferred)
GROWW_TOTP_SECRET=your_totp_secret
GROWW_TOTP_TOKEN=your_totp_api_key
GROWW_ACCESS_TOKEN=your_groww_token_fallback

# SQLite path (use Railway Volume mount path)
DB_PATH=trader_brain.db

# Safety
PAPER_MODE=true
CONFIRM_BEFORE_TRADE=true
BLOCK_ON_FILTER_ERROR=true
POSITION_STATE_FILE=position_state.json
SHADOW_MIN_WR=40

# Capital protection (salary trader defaults)
MAX_DAILY_LOSS_RS=5000
MAX_WEEKLY_LOSS_RS=5000
LIVE_CAPITAL_RS=5000
MAX_LOT_SIZE=1

# Paper → live graduation gates (leg-1 breakeven math ≈ 56% WR, 20+ paper trades)
MIN_PAPER_TRADES=20
MIN_PAPER_DAYS=14
# 4-week training plan: week 1–2 sim only, week 3–4 paper, then live gates
SIM_ONLY_DAYS=14
PAPER_PHASE_DAYS=14
LEARNING_PHASE_DAYS=14
SHADOW_LEARNING=true
SHADOW_MAX_PER_DAY=5
AUTO_PAPER_LEARNING=false

# Market simulator — virtual CE/PE on live flow (memory only, no Groww orders)
MARKET_SIM=true
SIM_MAX_PER_DAY=15
SIM_MAX_OPEN=2
SIM_SCAN_MINUTES=4
SIM_MIN_SCORE=4
SIM_MIN_GAP_MIN=8
SIM_MID_SNAPSHOT_MIN=5
VIRTUAL_TICK_SEC=10
VIRTUAL_TICK_IDLE_SEC=30
POSITION_WATCH_BNF_SEC=5
BNF_POLL_IDLE_SEC=10
BNF_MOVE_REFRESH=12
ANCHOR_MAX_AGE_SEC=40
MIN_OPT_LTP_SEC=3
NEAR_EXIT_PCT=0.08
VIRTUAL_REQUIRE_GROWW_LTP=true
GROWW_LTP_CACHE_SEC=10
GROWW_FEED_ENABLED=true
GROWW_FEED_RESYNC_SEC=20
GROWW_FEED_STALE_SEC=30
GROWW_FEED_WATCH_DEBOUNCE=0.5
BNF_POLL_FEED_IDLE_SEC=20
MIN_SIM_GRAD_SAMPLES=20
MIN_SIM_GRAD_WR=40
ACTIVITY_PULSE=true
ACTIVITY_PULSE_HOURS=10,12,14
MIN_WIN_RATE=56
MIN_PROFIT_FACTOR=1.2
MIN_PAPER_CONFIDENCE=60
MAX_CONSEC_LOSSES=3

# Paper realism (slippage model for live-like P&L)
PAPER_SLIPPAGE_PER_UNIT=7

# Virtual sim — live-like fills on same Groww WebSocket LTP (buy above / sell below LTP)
SIM_LIVE_FILLS=true
SIM_SLIPPAGE_PER_UNIT=7
SIM_SPREAD_PCT=1.0
MIN_PREMIUM_RS=80
MAX_PREMIUM_RS=450
MAX_SPREAD_PCT=8

# Salary-trader guards (₹5k option buying realities)
BLOCK_STALE_PRICE_TRADES=true
MAX_LOSS_PER_TRADE_PCT=25
NO_ENTRY_AFTER_HOUR=14
NO_ENTRY_AFTER_HOUR_WED=13
COLD_START_MIN_SCORE=8
COLD_START_MIN_TRADES_SCORE=7
WEDNESDAY_MIN_SCORE=8
MIN_DAYS_TO_EXPIRY=5
MAX_THETA_RISK_SCORE=55

# OpenAI coach (add OPENAI_API_KEY in .env — never commit)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=280

# Learning graduation — paper trade caps by phase
LEARNING_MAX_TRADES_DAY=2
POST_LEARNING_MAX_TRADES_DAY=2

# Ops — backups & uptime
BACKUP_DIR=backups
BACKUP_KEEP_DAYS=7
SIM_TICKS_KEEP_DAYS=30

# Sim Telegram — quiet during heavy training (daily digest via /simreport)
SIM_TELEGRAM_QUIET=true
SIM_TELEGRAM_CLOSE_MIN_PNL=150
SIM_TELEGRAM_MAX_PER_DAY=5
UPTIME_ALERT_MINUTES=30

# Shadow WR auto-tuning (raises min score when virtual drills underperform)
SHADOW_WR_FLOOR=40
SHADOW_TUNE_DAYS=14
SHADOW_MIN_SAMPLES=10

# Win-rate filters
MIN_FLOW_SCORE=4
FLOW_SCORE_BYPASS_AT=8
ZONE_CONFIRM_MINUTES=10
SWEET_PREMIUM_MIN=120
SWEET_PREMIUM_MAX=280
EXPIRY_WEEK_SHADOW_WR=50
EXPIRY_WEEK_SHADOW_MIN=5
SHADOW_LOSS_BLOCK_COUNT=2
SESSION_WR_FLOOR=35
SESSION_MIN_SAMPLES=5
OI_WALL_DISTANCE_PCT=0.3

# Trend / max pain
ADX_MIN=18
BLOCK_RANGING_LEARNING=true
MAX_PAIN_DIST_PCT=0.4

# ML Brain — Random Forest on virtual + paper outcomes
ML_LEARNING=true
ML_MIN_SAMPLES=25
ML_NN_MIN_SAMPLES=100
ML_NN_ENABLED=true
ML_MODEL_DIR=models
