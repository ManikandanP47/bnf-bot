# ─────────────────────────────────────────────────────
# Multi-Agent BankNifty Bot — Configuration
# Copy to .env and fill values
# In Railway: add as Environment Variables
# ─────────────────────────────────────────────────────

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Groww — data (LTP) + F&O execution (TOTP preferred)
GROWW_TOTP_SECRET=your_totp_secret
GROWW_TOTP_TOKEN=your_totp_api_key
GROWW_ACCESS_TOKEN=your_groww_token_fallback

# SQLite path (use Railway Volume mount path)
DB_PATH=trader_brain.db

# Safety
PAPER_MODE=true
CONFIRM_BEFORE_TRADE=true

# Capital protection (salary trader defaults)
MAX_DAILY_LOSS_RS=5000
MAX_WEEKLY_LOSS_RS=5000
LIVE_CAPITAL_RS=5000
MAX_LOT_SIZE=1

# Paper → live graduation gates (all must pass before live orders)
MIN_PAPER_TRADES=10
MIN_PAPER_DAYS=14
LEARNING_PHASE_DAYS=14
SHADOW_LEARNING=true
SHADOW_MAX_PER_DAY=5
ACTIVITY_PULSE=true
ACTIVITY_PULSE_HOURS=10,12,14
MIN_WIN_RATE=45
MIN_PROFIT_FACTOR=1.2
MIN_PAPER_CONFIDENCE=60
MAX_CONSEC_LOSSES=3

# Paper realism (slippage model for live-like P&L)
PAPER_SLIPPAGE_PER_UNIT=7
MIN_PREMIUM_RS=80
MAX_PREMIUM_RS=450
MAX_SPREAD_PCT=8

# Salary-trader guards (₹5k option buying realities)
BLOCK_STALE_PRICE_TRADES=true
MAX_LOSS_PER_TRADE_PCT=25
NO_ENTRY_AFTER_HOUR=14
NO_ENTRY_AFTER_HOUR_WED=13
COLD_START_MIN_SCORE=8
COLD_START_MIN_TRADES_SCORE=7
WEDNESDAY_MIN_SCORE=8
MIN_DAYS_TO_EXPIRY=5
MAX_THETA_RISK_SCORE=55

# OpenAI coach (add OPENAI_API_KEY in .env — never commit)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=280

# Learning graduation
LEARNING_MAX_TRADES_DAY=1
POST_LEARNING_MAX_TRADES_DAY=1

# Ops — backups & uptime
BACKUP_DIR=backups
BACKUP_KEEP_DAYS=7
UPTIME_ALERT_MINUTES=30

# Shadow WR auto-tuning (raises min score when virtual drills underperform)
SHADOW_WR_FLOOR=40
SHADOW_TUNE_DAYS=14
SHADOW_MIN_SAMPLES=10

# Win-rate filters
MIN_FLOW_SCORE=4
FLOW_SCORE_BYPASS_AT=8
ZONE_CONFIRM_MINUTES=10
SWEET_PREMIUM_MIN=120
SWEET_PREMIUM_MAX=280
EXPIRY_WEEK_SHADOW_WR=50
EXPIRY_WEEK_SHADOW_MIN=5
SHADOW_LOSS_BLOCK_COUNT=2
SESSION_WR_FLOOR=35
SESSION_MIN_SAMPLES=5
OI_WALL_DISTANCE_PCT=0.3

# Trend / max pain
ADX_MIN=18
BLOCK_RANGING_LEARNING=true
MAX_PAIN_DIST_PCT=0.4
